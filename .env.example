# --- Apify (discovery) -------------------------------------------------------
# Create a token at https://console.apify.com/account/integrations
APIFY_TOKEN=apify_api_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Judge (relevance scoring + comment drafting) ----------------------------
# The judge shells out to `claude -p`, which uses your LOCAL Claude Code
# subscription login — NOT a metered Anthropic API key. Nothing to set here as
# long as `claude` is installed and you are logged in (`claude` then /login).
#
# Optional overrides:
# JUDGE_MODEL=sonnet        # model alias passed to `claude -p --model` (default: sonnet)
# JUDGE_TIMEOUT_MS=120000   # per-call timeout for the claude subprocess
